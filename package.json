{
	"name": "uptimekit",
	"private": true,
	"type": "module",
	"version": "3.0.1",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@orpc/client": "latest",
			"@orpc/openapi": "latest",
			"@orpc/server": "latest",
			"@orpc/zod": "latest",
			"better-auth": "latest",
			"dotenv": "latest",
			"postgres": "latest",
			"zod": "latest",
			"drizzle-orm": "latest"
		}
	},
	"scripts": {
		"check": "bun run lint && bun run check-types && bun run test",
		"lint": "biome check .",
		"prepare": "husky || true",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"test": "cd apps/worker && go test ./...",
		"dev": "turbo dev",
		"dev:dash": "turbo -F @uptimekit/dash dev",
		"dev:status-page": "turbo -F @uptimekit/status-page dev",
		"db:push": "turbo -F @uptimekit/db db:push",
		"db:studio": "turbo -F @uptimekit/db db:studio",
		"db:generate": "turbo -F @uptimekit/db db:generate",
		"db:migrate": "turbo -F @uptimekit/db db:migrate",
		"ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
	},
	"dependencies": {
		"dotenv": "^17.4.1",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^22.19.17",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9.3",
		"turbo": "^2.9.5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"bun scripts/biome-safe.js"
		]
	},
	"packageManager": "bun@1.3.11"
}
