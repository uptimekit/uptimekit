{
	"name": "@uptimekit/api",
	"version": "2.0.3",
	"private": true,
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		},
		"./pkg/*": {
			"default": "./src/pkg/*/index.ts"
		},
		"./pkg/integrations/registry": {
			"default": "./src/pkg/integrations/registry.ts"
		},
		"./pkg/integrations/definitions/discord-meta": {
			"default": "./src/pkg/integrations/definitions/discord-meta.ts"
		},
		"./pkg/integrations/definitions/telegram-meta": {
			"default": "./src/pkg/integrations/definitions/telegram-meta.ts"
		},
		"./pkg/integrations/definitions/webhook-meta": {
			"default": "./src/pkg/integrations/definitions/webhook-meta.ts"
		},
		"./pkg/integrations/definitions/alertmanager-meta": {
			"default": "./src/pkg/integrations/definitions/alertmanager-meta.ts"
		},
		"./pkg/integrations/definitions/alertmanager": {
			"default": "./src/pkg/integrations/definitions/alertmanager.ts"
		}
	},
	"type": "module",
	"scripts": {},
	"devDependencies": {
		"@uptimekit/config": "workspace:2.0.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@clickhouse/client": "^1.15.0",
		"@node-rs/argon2": "^2.0.2",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@uptimekit/auth": "workspace:2.0.3",
		"@uptimekit/db": "workspace:2.0.3",
		"dotenv": "catalog:",
		"ioredis": "^5.8.2",
		"next": "^16.0.10",
		"zod": "catalog:"
	}
}
